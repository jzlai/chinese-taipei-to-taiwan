{
  "name": "Chinese Taipei to Taiwan",
  "description": "Replaces Chinese Taipei with 'Taiwan'",
  "version": "0.3.3",
  "manifest_version": 3,
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["script.js"],
      "all_frames": true,
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage"],
  "host_permissions": ["*://*/*"],
  "browser_specific_settings": {
    "gecko": {
      "id": "chinese-taipei-to-taiwan@example.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": "none"
      }
    }
  }
}
